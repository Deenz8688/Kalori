<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F5E9"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationLayout" />

    <!-- 🔥 BOTTOM MENU CUSTOM (Guna LinearLayout + weight) -->
    <LinearLayout
        android:id="@+id/bottomNavigationLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingVertical="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Button 1: Utama -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:background="@drawable/bg_tab_selector"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ic_home"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="@color/bottom_nav_color" />

            <TextView
                android:id="@+id/txt_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Utama"
                android:textSize="10sp"
                android:textColor="@color/bottom_nav_color" />
        </LinearLayout>

        <!-- Button 2: Kalori -->
        <LinearLayout
            android:id="@+id/nav_kalori"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:background="@drawable/bg_tab_selector"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ic_kalori"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_kalori"
                app:tint="@color/bottom_nav_color" />

            <TextView
                android:id="@+id/txt_kalori"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kalori"
                android:textSize="10sp"
                android:textColor="@color/bottom_nav_color" />
        </LinearLayout>

        <!-- Button 3: Laporan -->
        <LinearLayout
            android:id="@+id/nav_report"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:background="@drawable/bg_tab_selector"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ic_report"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_report"
                app:tint="@color/bottom_nav_color" />

            <TextView
                android:id="@+id/txt_report"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Laporan"
                android:textSize="10sp"
                android:textColor="@color/bottom_nav_color" />
        </LinearLayout>

        <!-- Button 4: Saya -->
        <LinearLayout
            android:id="@+id/nav_me"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:background="@drawable/bg_tab_selector"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/ic_me"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_user"
                app:tint="@color/bottom_nav_color" />

            <TextView
                android:id="@+id/txt_me"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saya"
                android:textSize="10sp"
                android:textColor="@color/bottom_nav_color" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>