<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ================= TAJUK ================= -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kira Kalori"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <!-- ================= FORM ADD MAKANAN ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tambah Makanan"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <!-- SPINNER -->

            <Spinner
                android:id="@+id/spinnerMeal"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp" />

            <!-- CARI MAKANAN -->

            <AutoCompleteTextView
                android:id="@+id/edtBreakfastFood"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:hint="Cari makanan..."
                android:background="@android:drawable/editbox_background"
                android:padding="12dp" />

            <!-- PILIHAN -->

            <RadioGroup
                android:id="@+id/radioGroupBreakfast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <RadioButton
                    android:id="@+id/radioBreakfastGram"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gram"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/radioBreakfastServing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hidangan"
                    android:layout_marginStart="20dp" />

            </RadioGroup>

            <!-- INPUT -->

            <AutoCompleteTextView
                android:id="@+id/edtBreakfastAmount"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:hint="Masukkan gram"
                android:inputType="numberDecimal"
                android:background="@android:drawable/editbox_background"
                android:padding="12dp" />

            <!-- BUTTON TAMBAH -->

            <Button
                android:id="@+id/btnAddBreakfast"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Tambah Hidangan"
                android:textStyle="bold"
                android:textColor="#000000"
                android:backgroundTint="#FFC107"
                android:layout_marginTop="16dp" />

            <LinearLayout
                android:id="@+id/layoutTempList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"/>

            <!-- BUTTON SIMPAN -->

            <Button
                android:id="@+id/btnSaveMeal"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Simpan Menu"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:layout_marginTop="12dp" />

            <!-- KALORI -->

            <TextView
                android:id="@+id/txtBreakfastCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kalori: 0 kcal"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:layout_marginTop="16dp" />

            <!-- TOTAL -->

            <TextView
                android:id="@+id/txtBreakfastTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jumlah Semasa: 0 kcal"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FF5722"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- ================= CARD MENU DISIMPAN ================= -->

        <LinearLayout
            android:id="@+id/layoutSavedMeals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp">

            <!-- CARD AKAN MUNCUL SINI -->

        </LinearLayout>

        <!-- ================= RINGKASAN ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:padding="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Ringkasan Harian"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/txtTotalCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jumlah Kalori: 0 kcal"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FF5722"
                android:layout_marginTop="20dp" />

            <TextView
                android:id="@+id/txtTdee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TDEE: 0 kcal"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/txtBmr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BMR: 0 kcal"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/txtBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Baki Kalori: 0 kcal"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#E91E63"
                android:layout_marginTop="16dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>